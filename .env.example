# Groq (free tier) -- https://console.groq.com/keys
GROQ_API_KEY=

# Adzuna (free tier) -- https://developer.adzuna.com/
# If left empty, the Job Search Agent automatically falls back to the
# no-key Arbeitnow API.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Two-letter country code Adzuna should search (us, gb, de, fr, ...)
ADZUNA_COUNTRY=us
