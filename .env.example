# --- Groq (free tier) -- https://console.groq.com/keys ---------------------
# Single key:
GROQ_API_KEY=
# OR a comma-separated list for automatic fallback when a key hits its
# rate limit (the client rotates to the next key on failure):
# GROQ_API_KEYS=gsk_first,gsk_second,gsk_third

# Optional model overrides (defaults shown):
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Adzuna (free tier) -- https://developer.adzuna.com/ --------------------
# If left empty, the Job Search Agent automatically falls back to the
# no-key Arbeitnow API.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Two-letter country code Adzuna should search (us, gb, de, fr, ...)
ADZUNA_COUNTRY=us

# --- LangSmith tracing (optional) -- https://smith.langchain.com ------------
# Set LANGSMITH_TRACING=true + an API key to see the full agent/LLM trace
# (LangGraph nodes, harness spans, every Groq call) in the LangSmith UI.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=job-match-ai
